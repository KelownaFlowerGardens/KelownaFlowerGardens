// sessions.db 

const session = require("express-session");
const SQLiteStore = require("connect-sqlite3")(session);

app.use(session({
  store: new SQLiteStore({
    db: "sessions.db",
    dir: "./",
    ttl: 86400
  }),
  secret: "supersecretkey",
  resave: false,
  saveUninitialized: false,
  cookie: {
    maxAge: 1000 * 60 * 60 * 24
  }
}));


